# Incubator (gym) environment — COMMITTED on purpose (ADR-006-A1 fail-closed contract).
# This is the ONLY supported way to run a Track-I / Track-S drill. It hard-points every
# storage target at a LOCAL MinIO 'gym-lake' bucket with FAKE creds so a sabotaged run can
# NEVER touch the live AWS bucket (novartis-pharma-sttm-lake) or the live Snowflake veneer.
#
# Usage (always):  set -a; source gym.env; set +a;  python scripts/gym_guard.py  &&  <drill cmd>
# The gym_guard preflight ABORTS if any of these is wrong (fail-closed) — see scripts/gym_guard.py.
#
# NOTE: a distinct BUCKET NAME ('gym-lake', not the prod 'novartis-pharma-sttm-lake') is the
# load-bearing guard — even if S3_ENDPOINT were somehow wrong, the bucket differs from prod.

GYM_MODE=1
S3_BUCKET=gym-lake
S3_ENDPOINT=localhost:9000
S3_USE_SSL=false
S3_URL_STYLE=path
# Memorable local gym creds. NOTE: MinIO root password must be >= 8 chars, so the secret is
# 'mangmang' (username stays 'mang'). Start MinIO with MINIO_ROOT_USER=mang / MINIO_ROOT_PASSWORD=mangmang.
AWS_ACCESS_KEY_ID=mang
AWS_SECRET_ACCESS_KEY=mangmang
AWS_REGION=ap-southeast-1
LAND_DATE=2026-06-18
DBT_PROFILES_DIR=.

# Spark + Delta DEMONSTRATION track (ADR-007 B3/B4) — SEPARATE bucket, SEPARATE prefix
# 'SPARK_*'. Spark reaches S3 through a different client (Hadoop s3a) than DuckDB's
# httpfs, so it gets its own guard (scripts/spark_gym_guard.py) and its own bucket —
# 'gym-lake-spark-staging' is NEVER the same as DuckDB's 'gym-lake' above, so a Spark
# drill can never collide with (or be mistaken for clearing) a DuckDB drill, and vice
# versa. Reuses the SAME local MinIO container (gym-minio), just a second bucket in it.
SPARK_S3_BUCKET=gym-lake-spark-staging
# Read-only source for the ADR-001 star inputs Spark demonstrates against (fence principle #4)
# — the DuckDB incubator's bucket, NEVER prod. Spark's factory only ever opens this for reads.
SPARK_READ_S3_BUCKET=gym-lake
SPARK_S3_ENDPOINT=localhost:9000
SPARK_AWS_ACCESS_KEY_ID=mang
SPARK_AWS_SECRET_ACCESS_KEY=mangmang
SPARK_AWS_REGION=ap-southeast-1
# sdkman-managed Java 21 candidate (ADR-007 B2) — Spark does not run on the
# Codespace-default Java 25; spark_session_factory() exports this per-invocation.
SPARK_JAVA_HOME=/usr/local/sdkman/candidates/java/21.0.10-ms
