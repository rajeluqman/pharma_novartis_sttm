# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# STACK: HYBRID вЂ” dev local (Docker Airflow + DuckDB), deploy cloud
# (AWS MWAA + Snowflake) in a SHORT window for portfolio artifacts.
# Locked stack = AWS В· MWAA В· Snowflake В· dbt. (No Databricks/Azure.)
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

# в”Ђв”Ђ Airflow (LOCAL dev via aws-mwaa-local-runner вЂ” no secret) в”Ђв”Ђ
# Runner reads its own .env.localrunner; mirrors MWAA runtime so DAGs port cleanly.
# Repo: https://github.com/aws/aws-mwaa-local-runner  (DAGsв†’dags/, depsв†’requirements/requirements.txt)
AIRFLOW_HOST=http://localhost:8080
AIRFLOW_USERNAME=airflow
AIRFLOW_PASSWORD=airflow

# в”Ђв”Ђ AWS (cloud deploy window) в”Ђв”Ђ
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1

# в”Ђв”Ђ ADR-007 B4: Spark+Delta DEMONSTRATION track real-AWS staging bucket в”Ђв”Ђ
# Distinct from the canonical lake (S3_BUCKET above) вЂ” provisioned via
# scripts/provision_s3_staging.sh. Run the ONE real demonstration via
# scripts/run_spark_demo_aws.sh (owner-gated вЂ” confirm before running; reads the real
# gold/_current/ read-only, writes Delta only to this bucket). That script sets
# SPARK_DEMO_MODE=1 so scripts/spark_gym_guard.py switches from drill rules to the B4
# demo rules вЂ” see that file for the full real-vs-drill rule set.
SPARK_STAGING_S3_BUCKET=novartis-pharma-sttm-spark-staging

# в”Ђв”Ђ ADR-007 B7: Slack alerting (env-only, never committed) в”Ђв”Ђ
# Create via api.slack.com/apps в†’ Incoming Webhooks в†’ Add New Webhook to Workspace.
# Empty/unset = Slack alerting disabled (no-op), not an error.
SLACK_WEBHOOK_URL=

# в”Ђв”Ђ AWS MWAA (Managed Airflow) в”Ђв”Ђ
# вљ пёЏ MWAA has NO free tier (~$0.49/hr в‰€ $350+/mo). Deploy short, then teardown.
MWAA_ENVIRONMENT_NAME=novartis-pharma-mwaa
MWAA_DAGS_S3_BUCKET=s3://<your-bucket>/dags
MWAA_DAGS_S3_PATH=dags

# в”Ђв”Ђ Snowflake (30-day trial, $400 credits) в”Ђв”Ђ
SNOWFLAKE_ACCOUNT=<account>
SNOWFLAKE_USER=<user>
SNOWFLAKE_PASSWORD=<password>
SNOWFLAKE_ROLE=<role>
SNOWFLAKE_WAREHOUSE=<wh>
SNOWFLAKE_DATABASE=<db>
SNOWFLAKE_SCHEMA=<schema>

# в”Ђв”Ђ dbt (targets Snowflake; profile read from here) в”Ђв”Ђ
DBT_PROFILES_DIR=./dbt
DBT_TARGET=dev

# в”Ђв”Ђ Data sources в”Ђв”Ђ
# Kaggle (Project Alpha: pharma-sales-data; Project Gamma: UCI drug reviews)
KAGGLE_USERNAME=
KAGGLE_KEY=
# FDA openFDA (Project Beta: NDC Directory) вЂ” optional API key raises rate limit
# https://open.fda.gov/apis/authentication/
OPENFDA_API_KEY=

# в”Ђв”Ђ Confluence (Atlassian Cloud вЂ” free tier, в‰¤10 users) в”Ђв”Ђ
# Used by Data Platform Engineer's scripts/publish_to_confluence.py to push
# architecture-approved AH.md / STTM.md. Token: id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_SITE_URL=https://<yoursite>.atlassian.net
CONFLUENCE_EMAIL=<your-atlassian-account-email>
CONFLUENCE_API_TOKEN=<api-token>
CONFLUENCE_SPACE_KEY=<space-key>
CONFLUENCE_PAGE_ID_AH=<architecture-handbook-page-id>
CONFLUENCE_PAGE_ID_ERD=<erd-page-id>
CONFLUENCE_PAGE_ID_STTM=<sttm-page-id>
